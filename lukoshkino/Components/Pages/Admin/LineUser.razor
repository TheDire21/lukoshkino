@using Microsoft.AspNetCore.Identity
@inject IdentityRedirectManager RedirectManager
@inject NavigationManager Navigation
@rendermode RenderMode.InteractiveServer
@inject IDbContextFactory<ApplicationContext> DbFactory

<div class="line">
    <h3 class="name_product">@User.Surname @User.Name @User.Patronymic</h3>
    <div class="check_box">
        <label>Администратор</label>
        <InputCheckbox Value="IsAdmin" ValueChanged="async (newValue) => await OnAdminChanged(newValue)" ValueExpression="() => IsAdmin" />
    </div>
    <button class="urna_btn" @onclick="ConfirmDelete"><img src="urna.png" alt="Удалить" /></button>
</div>

@if (ShowConfirmation)
{
    <div class="confirmation-dialog">
        <p>Вы уверены, что хотите удалить этого пользователя?</p>
        <button @onclick="DeleteUser">Да</button>
        <button @onclick="CancelDelete">Нет</button>
    </div>
}


@code {
    [Parameter] public ApplicationUser User { get; set; }
    private bool ShowConfirmation { get; set; }
    private bool IsAdmin;

    protected override async Task OnParametersSetAsync()
    {
        if (User != null)
        {
            IsAdmin = await HasAdminRole();
        }
    }

    private async Task<bool> HasAdminRole()
    {
        using var context = DbFactory.CreateDbContext();
        var adminRole = await context.Roles.FirstOrDefaultAsync(r => r.Name == "Admin");
        if (adminRole == null) return false;

        return await context.UserRoles
            .AnyAsync(ur => ur.UserId == User.Id && ur.RoleId == adminRole.Id);
    }

    private async Task OnAdminChanged(bool newValue)
    {
        using var context = DbFactory.CreateDbContext();

        var adminRole = await context.Roles.FirstOrDefaultAsync(r => r.Name == "Admin");
        if (adminRole == null) return;

        if (newValue)
        {
            context.UserRoles.Add(new IdentityUserRole<long>
                {
                    UserId = User.Id,
                    RoleId = adminRole.Id
                });
        }
        else
        {
            var roleToRemove = await context.UserRoles
                .FirstOrDefaultAsync(ur => ur.UserId == User.Id && ur.RoleId == adminRole.Id);
            if (roleToRemove != null)
            {
                context.UserRoles.Remove(roleToRemove);
            }
        }

        await context.SaveChangesAsync();
        IsAdmin = newValue;
    }

    private void ConfirmDelete()
    {
        ShowConfirmation = true;
    }

    private void CancelDelete()
    {
        ShowConfirmation = false;
    }

    private async Task DeleteUser()
    {
        try
        {
            await DeleteUserFromDatabase();
            ShowConfirmation = false;
            Navigation.NavigateTo("/admin/edit-goods", false);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка при удалении пользователя: {ex.Message}");
        }
    }

    private async Task DeleteUserFromDatabase()
    {
        await using var db = DbFactory.CreateDbContext();

        var userToDelete = await db.Users.FindAsync(User.Id);
        if (userToDelete != null)
        {
            db.Users.Remove(userToDelete);
            await db.SaveChangesAsync();
        }
        else
        {
            throw new InvalidOperationException("Пользователь не найден в базе данных.");
        }
    }


}
